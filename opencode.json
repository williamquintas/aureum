{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/gpt-5.1-codex",
  "instructions": ["AGENTS.md", ".opencode/context/core/standards/*.md"],
  "formatter": {
    "gofumpt": {
      "command": ["gofumpt", "-w", "$FILE"],
      "extensions": [".go"]
    },
    "goimports": {
      "command": ["goimports", "-w", "$FILE"],
      "extensions": [".go"]
    }
  },
  "lsp": {
    "typescript": {
      "disabled": true
    },
    "pyright": {
      "disabled": true
    }
  },
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": "allow",
    "task": "allow"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    }
  },
  "agent": {
    "build": {
      "permission": {
        "skill": {
          "aureum-workflow": "allow",
          "go-patterns": "allow",
          "cqrs-patterns": "allow",
          "testing-patterns": "allow"
        }
      }
    },
    "plan": {
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  },
  "command": {
    "test": {
      "template": "Run the full test suite and show failures with verbose output.",
      "description": "Run all tests",
      "agent": "build"
    },
    "lint": {
      "template": "Run golangci-lint and fix any issues found.",
      "description": "Run linter",
      "agent": "build"
    },
    "build": {
      "template": "Build all service binaries.",
      "description": "Build all services",
      "agent": "build"
    },
    "coverage": {
      "template": "Run tests with coverage report and verify 80%+ threshold.",
      "description": "Run coverage report",
      "agent": "build"
    }
  }
}
