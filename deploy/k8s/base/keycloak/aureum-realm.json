      },
      {
        "name": "user",
        "composite": false,
        "clientRole": false,
        "containerId": "aureum"
      },
      {
        "name": "readonly",
        "composite": false,
        "clientRole": false,
        "containerId": "aureum"
      }
    ]
  },
  "clients": [
